# Copy this file to backend/.env and fill in.

# Your Google Earth Engine Cloud project ID.
# Required. Example: ee-yourname or my-gee-project-123
GEE_PROJECT_ID=YOUR_GEE_PROJECT_ID

# Optional — service account auth. If set, backend will use this instead of
# user credentials. Point to an absolute path to a JSON key file.
# GEE_SERVICE_ACCOUNT=my-sa@my-gee-project-123.iam.gserviceaccount.com
# GEE_KEY_FILE=C:/path/to/service-account-key.json

# Optional — override CORS origin (defaults to http://localhost:5173)
# FRONTEND_ORIGIN=http://localhost:5173

# Vertex AI — required for /api/farm-view (Gemini zone analysis).
# GOOGLE_CLOUD_PROJECT can be the same project as GEE_PROJECT_ID.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Path to the Vertex service-account JSON key (Vertex AI User role).
# IMPORTANT: do NOT name this GOOGLE_APPLICATION_CREDENTIALS. If you do,
# Earth Engine will also pick it up and fail because that service account
# is not registered with Earth Engine.
VERTEX_KEY_FILE=./gcp-service-account.json
